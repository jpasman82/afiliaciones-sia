rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function esAdmin(uid) {
      return get(/databases/$(database)/documents/usuarios/$(uid)).data.rol == 'admin';
    }

    function esSupervisor(uid) {
      return get(/databases/$(database)/documents/usuarios/$(uid)).data.rol == 'supervisor';
    }

    function esAdminOSupervisor(uid) {
      let rol = get(/databases/$(database)/documents/usuarios/$(uid)).data.rol;
      return rol == 'admin' || rol == 'supervisor';
    }

    function rolActivo(uid) {
      let rol = get(/databases/$(database)/documents/usuarios/$(uid)).data.rol;
      return rol == 'admin' || rol == 'supervisor' || rol == 'afiliador';
    }

    match /usuarios/{uid} {
      // El propio usuario y admins/supervisores pueden leer
      allow read: if request.auth != null &&
        (request.auth.uid == uid || esAdminOSupervisor(request.auth.uid));
      // Un usuario puede crear su propio documento al registrarse por primera vez
      allow create: if request.auth != null && request.auth.uid == uid;
      // Admin: puede cambiar cualquier campo.
      // Supervisor: puede editar nombre/apellido y aprobar como afiliador (no puede asignar admin/supervisor).
      // El propio usuario: puede actualizar su perfil (nombre, apellido, perfilCompleto) sin cambiar su rol.
      allow update: if request.auth != null && (
        esAdmin(request.auth.uid) ||
        (esSupervisor(request.auth.uid) &&
          (request.resource.data.rol == resource.data.rol || request.resource.data.rol == 'afiliador')
        ) ||
        (request.auth.uid == uid && request.resource.data.rol == resource.data.rol)
      );
      allow delete: if request.auth != null && esAdmin(request.auth.uid);
    }

    match /afiliaciones/{docId} {
      // El afiliador ve sus propios registros; admins y supervisores ven todo
      allow read: if request.auth != null &&
        (resource.data.afiliadorUid == request.auth.uid || esAdminOSupervisor(request.auth.uid));
      // Solo usuarios activos pueden crear fichas con su propio uid
      allow create: if request.auth != null &&
        rolActivo(request.auth.uid) &&
        request.resource.data.afiliadorUid == request.auth.uid;
      // El dueño del registro, un admin o un supervisor pueden editarlo
      allow update: if request.auth != null &&
        (resource.data.afiliadorUid == request.auth.uid || esAdminOSupervisor(request.auth.uid));
      // Solo admins y supervisores pueden eliminar
      allow delete: if request.auth != null && esAdminOSupervisor(request.auth.uid);
    }
  }
}
